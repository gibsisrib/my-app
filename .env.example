# Copy to `.env` for local Expo / Metro. Only EXPO_PUBLIC_* is embedded in the client bundle.

# Meal AI: app calls this base URL + `/analyze-meal` (Expo Go replaces localhost with your PC IP when possible).
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787

# Server secrets for `npm run server` (same root `.env`, do NOT use EXPO_PUBLIC_ prefix):
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# TestFlight / App Store: set EXPO_PUBLIC_API_BASE_URL to your HTTPS API URL in EAS Secrets (or eas.json).
