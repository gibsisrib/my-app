# Copy to `.env` for local Expo / Metro. Only EXPO_PUBLIC_* is embedded in the client bundle.
# Do not add OpenAI or Gemini keys here — those belong only in the environment for `server/index.js`.

# Local dev (Expo Go replaces "localhost" with your dev machine IP when possible):
EXPO_PUBLIC_API_BASE_URL=http://localhost:8787

# TestFlight / App Store: must be a real HTTPS URL where you host server/index.js (e.g. Railway/Fly).
# Set the same variable in EAS: eas secret:create --name EXPO_PUBLIC_API_BASE_URL --value https://api.example.com
